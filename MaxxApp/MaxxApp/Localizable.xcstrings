    "gate.analytics.subtitle": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Track your glow score and mood trends over time. Upgrade for charts and insights."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시간에 따른 글로우 점수와 기분 변화를 추적하세요. 차트와 인사이트를 보려면 업그레이드하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Acompanhe seu glow score e tendências de humor ao longo do tempo. Assine para ver gráficos e insights."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfolge deinen Glow-Score und Stimmungstrends über die Zeit. Upgrade für Diagramme und Einblicke."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue tu glow score y tus tendencias de ánimo a lo largo del tiempo. Mejora para ver gráficos e información."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
