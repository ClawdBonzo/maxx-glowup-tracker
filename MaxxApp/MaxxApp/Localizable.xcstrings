    "This will permanently delete all your progress photos, routines, logs, and profile data. This cannot be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dadurch werden alle deine Fortschrittsfotos, Routinen, Protokolle und Profildaten dauerhaft gelöscht. Dies kann nicht rückgängig gemacht werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente todas tus fotos de progreso, rutinas, registros y datos de perfil. No se puede deshacer."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto eliminará permanentemente todas tus fotos de progreso, rutinas, registros y datos de perfil. No se puede deshacer."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모든 변화 사진, 루틴, 기록, 프로필 데이터가 영구적으로 삭제됩니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Isso excluirá permanentemente todas as suas fotos de progresso, rotinas, registros e dados de perfil. Esta ação não pode ser desfeita."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu, tüm ilerleme fotoğraflarını, rutinlerini, kayıtlarını ve profil verilerini kalıcı olarak siler. Bu işlem geri alınamaz."
          }
        }
      }
    },
