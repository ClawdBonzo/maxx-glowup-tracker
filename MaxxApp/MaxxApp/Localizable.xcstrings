    "ageInsight.midTwenties": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Konzentriere dich auf Vorbeugung und Pflege. Hautpflege und Fitness zahlen sich mit der Zeit aus."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Focus on prevention and maintenance. Skincare and fitness compound over time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Céntrate en la prevención y el mantenimiento. El cuidado de la piel y el ejercicio suman con el tiempo."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Enfócate en la prevención y el mantenimiento. El skincare y el ejercicio suman con el tiempo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예방과 관리에 집중하세요. 스킨케어와 운동은 시간이 지날수록 효과가 쌓입니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Foque em prevenção e manutenção. Skincare e treino se acumulam com o tempo."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önleme ve bakıma odaklan. Cilt bakımı ve fitness zamanla katlanarak fayda sağlar."
          }
        }
      }
    },
    "ageInsight.older": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es ist nie zu spät für ein Level-up. Kleine Veränderungen machen einen riesigen Unterschied."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "It's never too late to level up. Small changes make a huge difference."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca es tarde para mejorar. Los pequeños cambios marcan una gran diferencia."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca es tarde para mejorar. Los pequeños cambios hacen una gran diferencia."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변화에 늦은 때란 없어요. 작은 변화가 큰 차이를 만듭니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nunca é tarde para evoluir. Pequenas mudanças fazem uma enorme diferença."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelişmek için asla geç değil. Küçük değişiklikler büyük fark yaratır."
          }
        }
      }
    },
    "ageInsight.teen": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ideale Zeit, um früh gesunde Gewohnheiten aufzubauen. Deine Haut und dein Körper entwickeln sich noch!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Great time to build healthy habits early. Your skin and body are still developing!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es un buen momento para crear hábitos saludables pronto. ¡Tu piel y tu cuerpo aún se están desarrollando!"
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Es un gran momento para crear hábitos saludables desde joven. ¡Tu piel y tu cuerpo aún se están desarrollando!"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "건강한 습관을 일찍 들이기 좋은 시기예요. 피부와 몸이 아직 발달 중이니까요!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ótima fase para criar hábitos saudáveis cedo. Sua pele e seu corpo ainda estão se desenvolvendo!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sağlıklı alışkanlıkları erken edinmek için harika bir zaman. Cildin ve vücudun hâlâ gelişiyor!"
          }
        }
      }
    },
    "ageInsight.thirties": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Anti-Aging-Routinen werden jetzt zentral. Mit dem richtigen Ansatz erzielst du tolle Ergebnisse."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Anti-aging routines become key. You'll see incredible results with the right approach."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las rutinas antiedad se vuelven clave. Verás resultados increíbles con el enfoque adecuado."
          }
        },
        "es-MX": {
          "stringUnit": {
            "state": "translated",
            "value": "Las rutinas antiedad se vuelven clave. Verás resultados increíbles con el enfoque correcto."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "안티에이징 루틴이 핵심이 됩니다. 올바른 방법이면 놀라운 결과를 볼 수 있어요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Rotinas antienvelhecimento se tornam essenciais. Você verá resultados incríveis com a abordagem certa."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yaşlanma karşıtı rutinler artık kilit önemde. Doğru yaklaşımla inanılmaz sonuçlar göreceksin."
          }
        }
      }
    },
    "ageInsight.youngAdult": {
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die besten Glow-up-Jahre. Konsequenz zahlt sich später massiv aus."
